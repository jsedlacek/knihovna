{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "knihovna",
  "compatibility_date": "2025-09-15",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server-entry.ts",
  "assets": {
    "binding": "ASSETS",
  },
  "observability": {
    "traces": {
      "enabled": true,
      "head_sampling_rate": 1,
    },
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
  },
}

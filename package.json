{
  "name": "knihovna",
  "version": "1.0.0",
  "description": "Czech e-books static site",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "imports": {
    "#@/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "wrangler:types": "wrangler types",
    "typecheck": "tsgo",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run lint:imports && pnpm run format:check && pnpm test",
    "scrape": "node src/scripts/scrape-books.ts",
    "test": "LOG_LEVEL=silent node --test --test-reporter=./src/test/reporters/failures-only.ts src/**/*.test.ts",
    "test:verbose": "node --test --test-reporter=spec src/**/*.test.ts",
    "test:watch": "node --test --watch --test-reporter=spec src/**/*.test.ts",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "lint:imports": "node scripts/check-import-extensions.ts",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@logtape/logtape": "^2.0.4",
    "@logtape/pretty": "^2.0.4",
    "@tanstack/react-router": "^1.167.5",
    "@tanstack/react-start": "^1.166.17",
    "@tanstack/start-static-server-functions": "^1.166.15",
    "@types/lodash-es": "^4.17.12",
    "lodash-es": "^4.17.23",
    "lucide-react": "^0.577.0",
    "oxfmt": "^0.41.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@storybook/react-vite": "^10.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.35",
    "@typescript/native-preview": "7.0.0-dev.20260319.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cheerio": "^1.2.0",
    "domhandler": "^6.0.1",
    "oxlint": "^1.56.0",
    "storybook": "^10.3.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "wrangler": "^4.75.0",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": "24",
    "pnpm": "10"
  },
  "volta": {
    "node": "24.11.1"
  },
  "pnpm": {}
}
